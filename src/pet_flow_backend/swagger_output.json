{
  "swagger": "2.0",
  "info": {
    "title": "Pet Flow API",
    "description": "Documentação oficial da API do sistema Pet Flow para gestão de pet shops. Inclui módulos de Autenticação e Gestão Financeira.",
    "version": "1.2.0"
  },
  "host": "petflow-beta.vercel.app",
  "basePath": "/api/v1",
  "tags": [
    {
      "name": "Autenticação",
      "description": "Gestão de acesso e registro de funcionários"
    },
    {
      "name": "Financeiro",
      "description": "Controle de transações financeiras e fluxo de caixa"
    }
  ],
  "schemes": [
    "https",
    "http"
  ],
  "securityDefinitions": {
    "Bearer": {
      "type": "apiKey",
      "name": "Authorization",
      "in": "header",
      "description": "Insira o token JWT no formato: Bearer {token}"
    }
  },
  "paths": {
    "/auth/login": {
      "post": {
        "tags": [
          "Autenticação"
        ],
        "description": "Realiza o login de um funcionário na plataforma.",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "description": "Credenciais de acesso",
            "required": true,
            "schema": {
              "$ref": "#/definitions/LoginRequest"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Autenticado com sucesso",
            "schema": {
              "$ref": "#/definitions/AuthResponse"
            }
          },
          "401": {
            "description": "Credenciais inválidas"
          },
          "default": {
            "description": ""
          }
        }
      }
    },
    "/auth/register": {
      "post": {
        "tags": [
          "Autenticação"
        ],
        "description": "Registra um novo funcionário vinculado a uma clínica.",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "description": "Dados do novo funcionário",
            "required": true,
            "schema": {
              "$ref": "#/definitions/RegisterRequest"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Funcionário registrado com sucesso",
            "schema": {
              "$ref": "#/definitions/AuthResponse"
            }
          },
          "400": {
            "description": "Dados inválidos ou e-mail já em uso"
          },
          "default": {
            "description": ""
          }
        }
      }
    },
    "/financial/all": {
      "post": {
        "tags": [
          "Financeiro"
        ],
        "description": "Lista todas as transações financeiras filtradas por clínica e opcionalmente por funcionário.",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "description": "Filtros de busca",
            "required": true,
            "schema": {
              "$ref": "#/definitions/FinancialListRequest"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de transações recuperada com sucesso",
            "schema": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "example": "array"
                },
                "items": {
                  "$ref": "#/definitions/FinancialResponse"
                }
              },
              "xml": {
                "name": "main"
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/financial/detail": {
      "post": {
        "tags": [
          "Financeiro"
        ],
        "description": "Obtém os detalhes de uma transação financeira específica.",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "description": "Identificadores da transação",
            "required": true,
            "schema": {
              "$ref": "#/definitions/FinancialGetRequest"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Detalhes da transação",
            "schema": {
              "$ref": "#/definitions/FinancialResponse"
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Transação não encontrada ou acesso não autorizado"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/financial/": {
      "post": {
        "tags": [
          "Financeiro"
        ],
        "description": "Cria um novo registro de transação financeira.",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "description": "Dados da nova transação",
            "required": true,
            "schema": {
              "$ref": "#/definitions/FinancialCreateRequest"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Transação criada com sucesso",
            "schema": {
              "$ref": "#/definitions/FinancialResponse"
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "put": {
        "tags": [
          "Financeiro"
        ],
        "description": "Atualiza os dados de uma transação financeira existente.",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "description": "Dados atualizados da transação",
            "required": true,
            "schema": {
              "$ref": "#/definitions/FinancialUpdateRequest"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Transação atualizada com sucesso",
            "schema": {
              "$ref": "#/definitions/FinancialResponse"
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "delete": {
        "tags": [
          "Financeiro"
        ],
        "description": "Remove permanentemente uma transação financeira.",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "description": "Identificadores para exclusão",
            "required": true,
            "schema": {
              "$ref": "#/definitions/FinancialGetRequest"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Excluido com sucesso sem conteudo"
          },
          "400": {
            "description": "Falha na exclusao ou acesso negado"
          },
          "401": {
            "description": "Unauthorized"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/scheduling/": {
      "get": {
        "description": "",
        "parameters": [
          {
            "name": "authorization",
            "in": "header",
            "type": "string"
          }
        ],
        "responses": {
          "401": {
            "description": "Unauthorized"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "post": {
        "description": "",
