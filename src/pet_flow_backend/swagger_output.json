{
  "swagger": "2.0",
  "info": {
    "title": "Pet Flow API",
    "description": "Documentação oficial da API do sistema Pet Flow para gestão de pet shops. Inclui módulos de Autenticação, Gestão Financeira e Agendamentos.",
    "version": "1.2.0"
  },
  "host": "localhost:3000",
  "basePath": "/api/v1",
  "tags": [
    {
      "name": "Autenticação",
      "description": "Gestão de acesso e registro de funcionários"
    },
    {
      "name": "Financeiro",
      "description": "Controle de transações financeiras e fluxo de caixa"
    },
    {
      "name": "Agendamentos",
      "description": "Gestão de agendamentos de atendimento"
    },
    {
      "name": "Serviços",
      "description": "Cadastro e gestão de serviços oferecidos pelo pet shop"
    }
  ],
  "schemes": [
    "http"
  ],
  "securityDefinitions": {
    "bearerAuth": {
      "type": "apiKey",
      "name": "Authorization",
      "in": "header",
      "description": "Insira o token Bearer, ex: Bearer {token}"
    }
  },
  "paths": {
    "/auth/login": {
      "post": {
        "tags": [
          "Autenticação"
        ],
        "description": "Realiza o login de um funcionário na plataforma.",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "description": "Credenciais de acesso",
            "required": true,
            "schema": {
              "$ref": "#/definitions/LoginRequest"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Autenticado com sucesso",
            "schema": {
              "$ref": "#/definitions/AuthResponse"
            }
          },
          "401": {
            "description": "Credenciais inválidas"
          },
          "default": {
            "description": ""
          }
        }
      }
    },
    "/auth/register": {
      "post": {
        "tags": [
          "Autenticação"
        ],
        "description": "Registra um novo funcionário vinculado a uma clínica.",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "description": "Dados do novo funcionário",
            "required": true,
            "schema": {
              "$ref": "#/definitions/RegisterRequest"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Funcionário registrado com sucesso",
            "schema": {
              "$ref": "#/definitions/AuthResponse"
            }
          },
          "400": {
            "description": "Dados inválidos ou e-mail já em uso"
          },
          "default": {
            "description": ""
          }
        }
      }
    },
    "/financial/all": {
      "post": {
        "tags": [
          "Financeiro"
        ],
        "description": "Lista todas as transações financeiras filtradas por clínica e opcionalmente por funcionário.",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "description": "Filtros de busca",
            "required": true,
            "schema": {
              "$ref": "#/definitions/FinancialListRequest"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de transações recuperada com sucesso",
            "schema": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "example": "array"
                },
                "items": {
                  "$ref": "#/definitions/FinancialResponse"
                }
              },
              "xml": {
                "name": "main"
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/financial/detail": {
      "post": {
        "tags": [
          "Financeiro"
        ],
        "description": "Obtém os detalhes de uma transação financeira específica.",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "description": "Identificadores da transação",
            "required": true,
            "schema": {
              "$ref": "#/definitions/FinancialGetRequest"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Detalhes da transação",
            "schema": {
              "$ref": "#/definitions/FinancialResponse"
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Transação não encontrada ou acesso não autorizado"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/financial/": {
      "post": {
        "tags": [
          "Financeiro"
        ],
        "description": "Cria um novo registro de transação financeira.",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "description": "Dados da nova transação",
            "required": true,
            "schema": {
              "$ref": "#/definitions/FinancialCreateRequest"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Transação criada com sucesso",
            "schema": {
              "$ref": "#/definitions/FinancialResponse"
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "put": {
        "tags": [
          "Financeiro"
        ],
        "description": "Atualiza os dados de uma transação financeira existente.",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "description": "Dados atualizados da transação",
            "required": true,
            "schema": {
              "$ref": "#/definitions/FinancialUpdateRequest"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Transação atualizada com sucesso",
            "schema": {
              "$ref": "#/definitions/FinancialResponse"
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "delete": {
        "tags": [
          "Financeiro"
        ],
        "description": "Remove permanentemente uma transação financeira.",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "description": "Identificadores para exclusão",
            "required": true,
            "schema": {
              "$ref": "#/definitions/FinancialGetRequest"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Excluido com sucesso sem conteudo"
          },
          "400": {
            "description": "Falha na exclusao ou acesso negado"
          },
          "401": {
            "description": "Unauthorized"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/scheduling/": {
      "get": {
        "tags": [
          "Agendamentos"
        ],
        "description": "Lista todos os agendamentos cadastrados.",
        "responses": {
          "200": {
            "description": "Lista de agendamentos recuperada com sucesso",
            "schema": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "example": "array"
                },
                "items": {
                  "$ref": "#/definitions/SchedulingResponse"
                }
              },
              "xml": {
                "name": "main"
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "500": {
            "description": "Erro interno do servidor"
          }
        }
      },
      "post": {
        "tags": [
          "Agendamentos"
        ],
        "description": "Cria um novo agendamento.",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "description": "Dados do agendamento",
            "required": true,
            "schema": {
              "$ref": "#/definitions/SchedulingCreateRequest"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Agendamento criado com sucesso",
            "schema": {
              "$ref": "#/definitions/SchedulingResponse"
            }
          },
          "400": {
            "description": "Dados inválidos para criação"
          },
          "401": {
            "description": "Unauthorized"
          },
          "500": {
            "description": "Erro interno do servidor"
          }
        }
      }
    },
    "/scheduling/{id}": {
      "get": {
        "tags": [
          "Agendamentos"
        ],
        "description": "Busca um agendamento pelo identificador.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "ID do agendamento"
          }
        ],
        "responses": {
          "200": {
            "description": "Agendamento encontrado com sucesso",
            "schema": {
              "$ref": "#/definitions/SchedulingResponse"
            }
          },
          "400": {
            "description": "Parâmetros inválidos"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Agendamento não encontrado"
          },
          "500": {
            "description": "Erro interno do servidor"
          }
        }
      },
      "put": {
        "tags": [
          "Agendamentos"
        ],
        "description": "Atualiza um agendamento existente.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "ID do agendamento"
          },
          {
            "name": "body",
            "in": "body",
            "description": "Dados atualizados do agendamento",
            "required": true,
            "schema": {
              "$ref": "#/definitions/SchedulingUpdateRequest"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Agendamento atualizado com sucesso",
            "schema": {
              "$ref": "#/definitions/SchedulingResponse"
            }
          },
          "400": {
            "description": "Dados inválidos para atualização"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Agendamento não encontrado"
          },
          "500": {
            "description": "Erro interno do servidor"
          }
        }
      },
      "delete": {
        "tags": [
          "Agendamentos"
        ],
        "description": "Remove um agendamento existente.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "ID do agendamento"
          }
        ],
        "responses": {
          "204": {
            "description": "Agendamento removido com sucesso"
          },
          "400": {
            "description": "Parâmetros inválidos"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Agendamento não encontrado"
          },
          "500": {
            "description": "Erro interno do servidor"
          }
        }
      }
    },
    "/service/": {
      "get": {
        "tags": [
          "Serviços"
        ],
        "description": "Lista todos os serviços disponíveis.",
        "responses": {
          "200": {
            "description": "Lista de serviços recuperada com sucesso",
            "schema": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "example": "array"
                },
                "items": {
                  "$ref": "#/definitions/ServiceResponse"
                }
              },
              "xml": {
                "name": "main"
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "post": {
        "tags": [
          "Serviços"
        ],
        "description": "Cria um novo serviço.",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "description": "Dados do novo serviço",
            "required": true,
            "schema": {
              "$ref": "#/definitions/ServiceCreateRequest"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Serviço criado com sucesso",
            "schema": {
              "$ref": "#/definitions/ServiceResponse"
            }
          },
          "400": {
            "description": "Dados inválidos"
          },
          "401": {
            "description": "Unauthorized"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/service/{id}": {
      "get": {
        "tags": [
          "Serviços"
        ],
        "description": "Busca um serviço pelo ID.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "Serviço encontrado",
            "schema": {
              "$ref": "#/definitions/ServiceResponse"
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Serviço não encontrado"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "put": {
        "tags": [
          "Serviços"
        ],
        "description": "Atualiza os dados de um serviço existente.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "description": "Dados atualizados do serviço",
            "required": true,
            "schema": {
              "$ref": "#/definitions/ServiceUpdateRequest"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Serviço atualizado com sucesso",
            "schema": {
              "$ref": "#/definitions/ServiceResponse"
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Serviço não encontrado"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "delete": {
        "tags": [
          "Serviços"
        ],
        "description": "Remove permanentemente um serviço.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "204": {
            "description": "Serviço excluído com sucesso"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Serviço não encontrado"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    }
  },
  "definitions": {
    "LoginRequest": {
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "example": "funcionario@exemplo.com"
        },
        "password": {
          "type": "string",
          "example": "minhasenha123"
        }
      }
    },
    "RegisterRequest": {
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "example": "novo@exemplo.com"
        },
        "password": {
          "type": "string",
          "example": "senha-segura"
        }
      }
    },
    "AuthResponse": {
      "type": "object",
      "properties": {
        "user_id": {
          "type": "string",
          "example": "uuid-do-usuario"
        },
        "token": {
          "type": "string",
          "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
        }
      }
    },
    "FinancialListRequest": {
      "type": "object",
      "properties": {
        "clinic_id": {
          "type": "string",
          "example": "uuid-da-clinica"
        },
        "employee_id": {
          "type": "string",
          "example": "uuid-do-funcionario (opcional)"
        }
      }
    },
    "FinancialGetRequest": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "example": "uuid-da-transacao"
        },
        "clinic_id": {
          "type": "string",
          "example": "uuid-da-clinica"
        }
      }
    },
    "FinancialCreateRequest": {
      "type": "object",
      "properties": {
        "idx": {
          "type": "number",
          "example": 0
        },
        "scheduling_id": {
          "type": "string",
          "example": "uuid-do-agendamento"
        },
        "description": {
          "type": "string",
          "example": "Pagamento de Banho e Tosa"
        },
        "amount": {
          "type": "number",
          "example": 150
        },
        "payment_method": {
          "type": "string",
          "example": "Cartão de Crédito"
        },
        "clinic_id": {
          "type": "string",
          "example": "uuid-da-clinica"
        }
      }
    },
    "FinancialUpdateRequest": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "example": "uuid-da-transacao"
        },
        "clinic_id": {
          "type": "string",
          "example": "uuid-da-clinica"
        },
        "idx": {
          "type": "number",
          "example": 0
        },
        "description": {
          "type": "string",
          "example": "Manutenção de Equipamento"
        },
        "amount": {
          "type": "number",
          "example": 300
        },
        "payment_method": {
          "type": "string",
          "example": "Pix"
        }
      }
    },
    "FinancialResponse": {
      "type": "object",
      "properties": {
        "idx": {
          "type": "number",
          "example": 0
        },
        "id": {
          "type": "string",
          "example": "uuid-da-transacao"
        },
        "scheduling_id": {
          "type": "string",
          "example": "uuid-do-agendamento"
        },
        "description": {
          "type": "string",
          "example": "Pagamento de Banho e Tosa"
        },
        "amount": {
          "type": "number",
          "example": 150
        },
        "payment_method": {
          "type": "string",
          "example": "Cartão de Crédito"
        },
        "employee_id": {
          "type": "string",
          "example": "uuid-do-funcionario"
        },
        "clinic_id": {
          "type": "string",
          "example": "uuid-da-clinica"
        },
        "created_at": {
          "type": "string",
          "example": "2026-03-31T20:00:00Z"
        }
      }
    },
    "SchedulingCreateRequest": {
      "type": "object",
      "properties": {
        "clinicId": {
          "type": "string",
          "example": "uuid-da-clinica"
        },
        "tutorId": {
          "type": "string",
          "example": "uuid-do-tutor"
        },
        "petId": {
          "type": "string",
          "example": "uuid-do-pet"
        },
        "employeeId": {
          "type": "string",
          "example": "uuid-do-funcionario"
        },
        "dateTime": {
          "type": "string",
          "example": "2026-04-10T14:00:00.000Z"
        },
        "status": {
          "type": "string",
          "example": "Agendado"
        },
        "totalValue": {
          "type": "number",
          "example": 120
        },
        "notes": {
          "type": "string",
          "example": "Banho e tosa completa"
        }
      }
    },
    "SchedulingUpdateRequest": {
      "type": "object",
      "properties": {
        "clinicId": {
          "type": "string",
          "example": "uuid-da-clinica"
        },
        "tutorId": {
          "type": "string",
          "example": "uuid-do-tutor"
        },
        "petId": {
          "type": "string",
          "example": "uuid-do-pet"
        },
        "employeeId": {
          "type": "string",
          "example": "uuid-do-funcionario"
        },
        "dateTime": {
          "type": "string",
          "example": "2026-04-11T10:30:00.000Z"
        },
        "status": {
          "type": "string",
          "example": "Confirmado"
        },
        "totalValue": {
          "type": "number",
          "example": 140
        },
        "notes": {
          "type": "string",
          "example": "Confirmado por telefone"
        }
      }
    },
    "SchedulingResponse": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "example": "uuid-do-agendamento"
        },
        "clinicId": {
          "type": "string",
          "example": "uuid-da-clinica"
        },
        "tutorId": {
          "type": "string",
          "example": "uuid-do-tutor"
        },
        "petId": {
          "type": "string",
          "example": "uuid-do-pet"
        },
        "employeeId": {
          "type": "string",
          "example": "uuid-do-funcionario"
        },
        "dateTime": {
          "type": "string",
          "example": "2026-04-10T14:00:00.000Z"
        },
        "status": {
          "type": "string",
          "example": "Agendado"
        },
        "totalValue": {
          "type": "number",
          "example": 120
        },
        "notes": {
          "type": "string",
          "example": "Banho e tosa completa"
        },
        "createdAt": {
          "type": "string",
          "example": "2026-04-01T12:00:00.000Z"
        }
      }
    },
    "ServiceCreateRequest": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "example": "Banho e tosa"
        },
        "description": {
          "type": "string",
          "example": "Banho e tosa em cachorro"
        },
        "price": {
          "type": "number",
          "example": 90
        },
        "duration": {
          "type": "number",
          "example": 90
        }
      }
    },
    "ServiceUpdateRequest": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "example": "Banho e tosa"
        },
        "description": {
          "type": "string",
          "example": "Banho e tosa completo"
        },
        "price": {
          "type": "number",
          "example": 100
        },
        "duration": {
          "type": "number",
          "example": 90
        }
      }
    },
    "ServiceResponse": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "example": "uuid-do-servico"
        },
        "name": {
          "type": "string",
          "example": "Banho e tosa"
        },
        "description": {
          "type": "string",
          "example": "Banho e tosa completo"
        },
        "price": {
          "type": "number",
          "example": 120
        },
        "duration": {
          "type": "number",
          "example": 90
        }
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ]
}