  "definitions": {
    "LoginRequest": {
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "example": "funcionario@exemplo.com"
        },
        "password": {
          "type": "string",
          "example": "minhasenha123"
        }
      }
    },
    "RegisterRequest": {
      "type": "object",
      "properties": {
        "clinicId": {
          "type": "string",
          "example": "uuid-da-clinica"
        },
        "name": {
          "type": "string",
          "example": "Nome do Funcionário"
        },
        "email": {
          "type": "string",
          "example": "novo@exemplo.com"
        },
        "password": {
          "type": "string",
          "example": "senha-segura"
        },
        "role": {
          "type": "string",
          "example": "Atendente"
        },
        "phone": {
          "type": "string",
          "example": "11988887777"
        }
      }
    },
    "AuthResponse": {
      "type": "object",
      "properties": {
        "user_id": {
          "type": "string",
          "example": "uuid-do-usuario"
        },
        "token": {
          "type": "string",
          "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
        }
      }
    },
    "FinancialListRequest": {
      "type": "object",
      "properties": {
        "clinicId": {
          "type": "string",
          "example": "uuid-da-clinica"
        },
        "employeeId": {
          "type": "string",
          "example": "uuid-do-funcionario (opcional)"
        }
      }
    },
    "FinancialGetRequest": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "example": "uuid-da-transacao"
        },
        "clinicId": {
          "type": "string",
          "example": "uuid-da-clinica"
        }
      }
    },
    "FinancialCreateRequest": {
      "type": "object",
      "properties": {
        "schedulingId": {
          "type": "string",
          "example": "uuid-do-agendamento"
        },
        "category": {
          "type": "string",
          "example": "Receita"
        },
        "description": {
          "type": "string",
          "example": "Pagamento de Banho e Tosa"
        },
        "amount": {
          "type": "number",
          "example": 150
        },
        "paymentDate": {
          "type": "string",
          "example": "2026-03-31"
        },
        "paymentMethod": {
          "type": "string",
          "example": "Cartão de Crédito"
        },
        "clinicId": {
          "type": "string",
          "example": "uuid-da-clinica"
        }
      }
    },
    "FinancialUpdateRequest": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "example": "uuid-da-transacao"
        },
        "clinicId": {
          "type": "string",
          "example": "uuid-da-clinica"
        },
        "category": {
          "type": "string",
          "example": "Despesa"
        },
        "description": {
          "type": "string",
          "example": "Manutenção de Equipamento"
        },
        "amount": {
          "type": "number",
          "example": 300
        },
        "paymentDate": {
          "type": "string",
          "example": "2026-04-05"
        },
        "paymentMethod": {
          "type": "string",
          "example": "Pix"
        }
      }
    },
    "FinancialResponse": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "example": "uuid-da-transacao"
        },
        "schedulingId": {
          "type": "string",
          "example": "uuid-do-agendamento"
        },
        "category": {
          "type": "string",
          "example": "Receita"
        },
        "description": {
          "type": "string",
          "example": "Pagamento de Banho e Tosa"
        },
        "amount": {
          "type": "number",
          "example": 150
        },
        "paymentDate": {
          "type": "string",
          "example": "2026-03-31"
        },
        "paymentMethod": {
          "type": "string",
          "example": "Cartão de Crédito"
        },
        "employeeId": {
          "type": "string",
          "example": "uuid-do-funcionario"
        },
        "clinicId": {
          "type": "string",
          "example": "uuid-da-clinica"
        },
        "createdAt": {
          "type": "string",
          "example": "2026-03-31T20:00:00Z"
        }
      }
    }
  }
}