{
  "swagger": "2.0",
  "info": {
    "title": "Pet Flow API",
    "description": "Documentação da API para o Sistema de Pet Shop (Minimalist Version)",
    "version": "1.1.0"
  },
  "host": "localhost:3000",
  "basePath": "/api/v1",
  "schemes": [
    "http"
  ],
  "securityDefinitions": {
    "Bearer": {
      "type": "apiKey",
      "name": "Authorization",
      "in": "header",
      "description": "Insira o token JWT no formato: Bearer {token}"
